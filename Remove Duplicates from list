# Program to remove duplicates from a list

n=int(input("How many values you want= "))
if n<=0:
    pass
else:
    lst=[]
    for i in range(1,n+1):
        val=int(input("Enter {} value= ".format(i)))
        lst.append(val)

    else:
        print("values are={}".format(lst))
        lst2=[]

        for i in lst:
            if i not in lst2:
                lst2.append(i)

        else:
            print("Unique values are={}".format(lst2))
